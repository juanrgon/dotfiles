#!/bin/bash

# Global variables
DRY_RUN=false
REMOTE=false
VISIBILITY="private"
DESCRIPTION=""

# Function to check if gh CLI is available and authenticated
check_gh_cli() {
    if ! command -v gh >/dev/null 2>&1; then
        echo "Error: GitHub CLI (gh) is not installed."
        echo "Install it from: https://cli.github.com/"
        exit 1
    fi

    if ! gh auth status >/dev/null 2>&1; then
        echo "Error: GitHub CLI is not authenticated."
        echo "Run 'gh auth login' to authenticate."
        exit 1
    fi
}

# Function to get the authenticated user's GitHub handle
get_github_handle() {
    gh api user --jq '.login'
}

# Parse command line arguments
REPO_ARG=""
while [[ $# -gt 0 ]]; do
    case $1 in
        -n|--dry-run)
            DRY_RUN=true
            shift
            ;;
        -r|--remote)
            REMOTE=true
            shift
            ;;
        --public)
            REMOTE=true
            VISIBILITY="public"
            shift
            ;;
        --private)
            REMOTE=true
            VISIBILITY="private"
            shift
            ;;
        -d|--description)
            REMOTE=true
            DESCRIPTION="$2"
            shift 2
            ;;
        -h|--help)
            echo "Usage: $0 [OPTIONS] <repo>"
            echo ""
            echo "Create a new git repository at ~/github.com/org/repo"
            echo ""
            echo "By default, creates a local-only repository. Use --remote to also"
            echo "create the repository on GitHub."
            echo ""
            echo "Arguments:"
            echo "  <repo>    Repository in one of these formats:"
            echo "            - repo         (creates under your account)"
            echo "            - org/repo     (creates under the specified org)"
            echo ""
            echo "Options:"
            echo "  -r, --remote         Also create the repository on GitHub"
            echo "  --public             Create a public GitHub repository (implies --remote)"
            echo "  --private            Create a private GitHub repository (implies --remote)"
            echo "  -d, --description    Repository description (implies --remote)"
            echo "  -n, --dry-run        Show what would be done without executing"
            echo "  -h, --help           Show this help message"
            exit 0
            ;;
        -*|--*)
            echo "Unknown option $1"
            echo "Use --help for usage information"
            exit 1
            ;;
        *)
            if [ -n "$REPO_ARG" ]; then
                echo "Error: Multiple repository arguments provided"
                echo "Use --help for usage information"
                exit 1
            fi
            REPO_ARG="$1"
            shift
            ;;
    esac
done

# Check if a repository argument is provided
if [ -z "$REPO_ARG" ]; then
    echo "Error: Repository argument is required"
    echo "Usage: $0 [OPTIONS] <repo>"
    echo "Use --help for more information"
    exit 1
fi

# Only need gh CLI for remote creation or org lookup
if [ "$REMOTE" = true ]; then
    check_gh_cli
fi

# Parse org and repo from the input
if [[ $REPO_ARG =~ / ]]; then
    # Validate org/repo format (one slash, both parts non-empty)
    if [[ ! $REPO_ARG =~ ^[^/]+/[^/]+$ ]]; then
        echo "Error: Invalid repository format: $REPO_ARG"
        echo "Supported formats:"
        echo "  - repo"
        echo "  - org/repo"
        exit 1
    fi
    ORG=$(echo "$REPO_ARG" | cut -d '/' -f 1)
    REPO=$(echo "$REPO_ARG" | cut -d '/' -f 2)
else
    REPO="$REPO_ARG"
    check_gh_cli
    ORG=$(get_github_handle)
fi

# Validate parsed values
if [ -z "$ORG" ] || [ -z "$REPO" ]; then
    echo "Error: Could not parse valid org/repo from input: $REPO_ARG"
    echo "Supported formats:"
    echo "  - repo"
    echo "  - org/repo"
    exit 1
fi

# Validate repo name format
if [[ ! $REPO =~ ^[a-zA-Z0-9._-]+$ ]]; then
    echo "Error: Invalid repository name format: $REPO"
    exit 1
fi

# Define the target directory
TARGET_DIR="$HOME/github.com/$ORG/$REPO"

if [ "$DRY_RUN" = true ]; then
    echo "=== DRY RUN MODE ==="
    echo "Input: $REPO_ARG"
    echo "Parsed org: $ORG"
    echo "Parsed repo: $REPO"
    if [ "$REMOTE" = true ]; then
        echo "Remote: yes"
        echo "Visibility: $VISIBILITY"
        if [ -n "$DESCRIPTION" ]; then
            echo "Description: $DESCRIPTION"
        fi
    else
        echo "Remote: no (local only)"
    fi
    echo "Target directory: $TARGET_DIR"
    echo ""
fi

# Check if the remote repository already exists
if [ "$REMOTE" = true ] && gh repo view "$ORG/$REPO" >/dev/null 2>&1; then
    echo "Error: Repository $ORG/$REPO already exists on GitHub."
    echo "Use 'gitget $ORG/$REPO' to clone it instead."
    exit 1
fi

if [ "$DRY_RUN" = true ] && [ "$REMOTE" = true ]; then
    echo "✓ Repository $ORG/$REPO does not already exist on GitHub"
fi

# Check if the target directory already exists
if [ -d "$TARGET_DIR" ]; then
    echo "Error: The directory $TARGET_DIR already exists."
    exit 1
fi

if [ "$DRY_RUN" = true ]; then
    echo "✓ Target directory $TARGET_DIR does not exist"
    echo ""
    echo "Would execute:"
    echo "  mkdir -p \"$TARGET_DIR\""
    echo "  cd \"$TARGET_DIR\""

    if [ "$REMOTE" = true ]; then
        CREATE_CMD="  gh repo create \"$ORG/$REPO\" --\"$VISIBILITY\" --clone"
        if [ -n "$DESCRIPTION" ]; then
            CREATE_CMD="$CREATE_CMD --description \"$DESCRIPTION\""
        fi
        echo "$CREATE_CMD"
    else
        echo "  git init"
    fi

    echo ""
    echo "=== DRY RUN COMPLETE ==="
    exit 0
fi

# Create the target directory
mkdir -p "$TARGET_DIR"
cd "$TARGET_DIR" || exit

if [ "$REMOTE" = true ]; then
    # Create the repository on GitHub and clone it
    CREATE_ARGS=("$ORG/$REPO" "--$VISIBILITY" "--clone")
    if [ -n "$DESCRIPTION" ]; then
        CREATE_ARGS+=("--description" "$DESCRIPTION")
    fi

    if ! gh repo create "${CREATE_ARGS[@]}"; then
        echo "Error: Failed to create repository $ORG/$REPO"
        rmdir "$TARGET_DIR" 2>/dev/null
        exit 1
    fi

    echo "Repository $ORG/$REPO has been created and cloned into $TARGET_DIR"
else
    # Local-only: just git init
    git init

    echo "Repository created at $TARGET_DIR"
fi

echo "$TARGET_DIR"
